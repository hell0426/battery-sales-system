# --- Java/Spring Boot 忽略项 ---
backend/target/
backend/.idea/
backend/*.iml
backend/.mvn/
backend/mvnw
backend/mvnw.cmd

# --- Vue/Node 忽略项 (超级重要，否则Git会崩溃) ---
frontend/node_modules/
frontend/dist/
frontend/.vscode/
frontend/*.log

# --- IDE 配置（所有层级） ---
**/.idea/
**/*.iml
.vscode/

# --- Claude Code 本地配置 ---
.claude/
.claudeignore

# --- Spring Initializr 附带的无用文件 ---
backend/HELP.md

# --- 系统忽略项 ---
.DS_Store
Thumbs.db
